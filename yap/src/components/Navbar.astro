<header
id="navbar"
class="
fixed
top-0
left-0
w-full
z-50
transition-all
duration-300
"
>

<nav
class="
max-w-7xl
mx-auto
flex
items-center
justify-between
px-4
sm:px-8
py-5
"
>

<!-- LOGO -->

<a
href="/"
id="logo"
class="
text-lg
sm:text-2xl
font-bold
text-white
transition
whitespace-nowrap
"
>
Yap Wellness Center
</a>


<!-- DESKTOP MENU -->

<div
class="
hidden
lg:flex
items-center
gap-10
font-medium
"
>

<a href="#about"
class="nav-link text-white transition hover:text-teal-400">
About
</a>

<a href="#structure"
class="nav-link text-white transition hover:text-teal-400">
Structure
</a>

<a href="#approach"
class="nav-link text-white transition hover:text-teal-400">
Approach
</a>

<a href="#admissions"
class="nav-link text-white transition hover:text-teal-400">
Admissions
</a>

<a href="#location"
class="nav-link text-white transition hover:text-teal-400">
Location
</a>

</div>


<!-- CONTACT BUTTON -->

<button
id="contactBtn"
type="button"
class="
bg-teal-600
hover:bg-teal-700
text-white
px-4
sm:px-6
py-2.5
sm:py-3
rounded-full
font-medium
text-sm
sm:text-base
whitespace-nowrap
transition
"
>
Contact Us
</button>


</nav>

</header>


<style>

.contact-highlight{

animation:contactPulse 2s ease;

}

@keyframes contactPulse{

0%{
box-shadow:0 0 0 0 rgba(20,184,166,.7);
}

50%{
box-shadow:0 0 0 12px rgba(20,184,166,.25);
}

100%{
box-shadow:0 0 0 0 rgba(20,184,166,0);
}

}

</style>


<script>

const navbar = document.getElementById("navbar");
const logo = document.getElementById("logo");
const links = document.querySelectorAll(".nav-link");
const contactBtn = document.getElementById("contactBtn");


/*
Navbar background on scroll
*/

window.addEventListener("scroll", () => {

if(window.scrollY > 50){

navbar.classList.add(
"bg-white",
"shadow-md"
);

logo.classList.remove(
"text-white"
);

logo.classList.add(
"text-slate-900"
);


links.forEach(link=>{

link.classList.remove(
"text-white"
);

link.classList.add(
"text-slate-700"
);

});


}else{


navbar.classList.remove(
"bg-white",
"shadow-md"
);


logo.classList.add(
"text-white"
);

logo.classList.remove(
"text-slate-900"
);


links.forEach(link=>{

link.classList.add(
"text-white"
);

link.classList.remove(
"text-slate-700"
);

});


}

});


/*
Contact button scroll
*/

contactBtn.addEventListener("click",()=>{

const contactSection = document.getElementById("contact");


if(!contactSection){
console.warn("Contact section with id='contact' was not found.");
return;
}


contactSection.scrollIntoView({

behavior:"smooth",

block:"start"

});


setTimeout(()=>{

contactSection.classList.add(
"contact-highlight"
);


setTimeout(()=>{

contactSection.classList.remove(
"contact-highlight"
);

},2000);


},700);


});


</script>